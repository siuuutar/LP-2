# Simple Hospital Chatbot

print("=== Hospital Help Chatbot ===")
print("Type 'exit' to stop\n")

while True:

    user = input("You: ").lower()

    if user == "hello" or user == "hi":
        print("Bot: Welcome to City Hospital.")

    elif "doctor" in user:
        print("Bot: Doctors are available from 10 AM to 5 PM.")

    elif "appointment" in user:
        print("Bot: Appointment can be booked at reception.")

    elif "emergency" in user:
        print("Bot: Emergency service is available 24/7.")

    elif "fees" in user:
        print("Bot: Consultation fee is Rs.500.")

    elif user == "exit":
        print("Bot: Thank you. Get well soon!")
        break

    else:
        print("Bot: Sorry, please try another question.")
