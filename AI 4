def solve_n_queens(n):
    board = [-1] * n # board[i] = column of queen in row i
    def is_safe(row, col):
        for i in range(row):
# same column OR diagonal attack
            if board[i] == col or abs(board[i] - col) == abs(i - row):
                return False
        return True
    def backtrack(row):
        if row == n:
            print(board) # solution found
            return
        for col in range(n):
# Branch & Bound: prune invalid choices early
            if is_safe(row, col):
                board[row] = col
                backtrack(row + 1)
                board[row] = -1 # backtrack
    backtrack(0)
# Example
solve_n_queens(4)
