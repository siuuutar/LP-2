def solve_n_queens(n):
    board = [-1] * n 
    results = []

    def is_safe(row, col):
        for prev_row in range(row):
            if board[prev_row] == col:
                return False

            if abs(board[prev_row] - col) == abs(prev_row - row):
                return False

        return True

    def backtrack(row):
        if row == n:
            results.append(board[:])
            return True

        for col in range(n):
            if is_safe(row, col):
                board[row] = col   # Place queen

                if backtrack(row + 1):
                    return True

                board[row] = -1    # Remove queen

        return False

    backtrack(0)
    return results[0]

solution = solve_n_queens(4)

print("Queen Positions:")
print(solution)

n = 4
for row in range(n):
    for col in range(n):
        if solution[row] == col:
            print("Q", end=" ")
        else:
            print(".", end=" ")
    print()
